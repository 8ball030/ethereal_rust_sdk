                    },
                    "s": {
                      "type": "string"
                    },
                    "sid": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "sn": {
                      "type": "string"
                    },
                    "st": {
                      "type": "string"
                    },
                    "t": {
