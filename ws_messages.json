                    "sid": {
                      "type": "string",
                      "format": "uuid"
                    },
                    "s": {
                      "type": "string"
                    },
                    "sd": {
                      "type": "integer",
                      "enum": [0, 1]
                    },
                    "sz": {
                      "type": "string"
                    },
                    "cost": {
                      "type": "string"
                    },
                    "rpnl": {
                      "type": "string"
                    },
                    "fpnl": {
                      "type": "string"
                    },
                    "fee": {
                      "type": "string"
                    },
                    "lpx": {
                      "type": "string"
                    }
                  },
                  "required": ["id", "sid", "s", "sd", "sz", "cost", "rpnl", "fpnl", "fee"]
                }
              }
            },
            "required": ["t", "d"]
          }
        },
        "required": ["e", "t", "data"]
      },

